{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/app/page.tsx", "src/app/api/**/*.ts"],
  "project": ["src/**/*.{js,ts,tsx}", "*.ts", "*.mjs"],
  "ignore": ["**/*.d.ts", "src/mocks/**"],
  "ignoreDependencies": ["xvfb", "ripgrep", "tree", "tailwindcss", "postcss"],
  "ignoreBinaries": ["playwright", "prettier", "knip"]
}
